# ==================== 模型配置 ====================
# 主模型 API Key（DeepSeek / OpenAI 兼容接口）
OPENAI_API_KEY=your_openai_api_key_here
# 主模型 Base URL
BASE_URL=https://api.deepseek.com
# 主模型名称
MODEL=deepseek-v4-pro

# 代码模型 API Key（阿里云 DashScope）
CODING_API_KEY=your_dashscope_api_key_here
# 代码模型 Base URL
CODING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 视觉模型名称（需支持多模态）
VISION_MODEL=qwen3.6-plus
# 代码模型名称
CODING_MODEL=qwen-coder-max
# 评分模型名称
GRADE_MODEL=qwen3-max

# ==================== 天气 API ====================
WEATHER_API_KEY=your_weather_api_key_here

# ==================== 百度搜索 API ====================
BAIDU_WEB_SEARCH_API_KEY=your_baidu_search_api_key_here

# ==================== 微信公众号配置 ====================
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here
WECHAT_TOKEN=your_wechat_token_here
WECHAT_TEMPLATE_ID=your_wechat_template_id_here
WECHAT_DEFAULT_OPENID=your_default_openid_here

# ==================== HuggingFace Embedding ====================
HF_EMBEDDING_MODEL_PATH=path_to_your_embedding_model

# ==================== 摄像头配置（可选）====================
# CAMERA_INDEX=0
# CAMERA_WIDTH=1280
# CAMERA_HEIGHT=720
# CAMERA_FPS=30
# FRAME_SAVE_DIR=/tmp/vision_frames
